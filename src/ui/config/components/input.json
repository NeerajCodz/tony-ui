{
  "version": "1.0",
  "component": "input",
  "description": "Cyber HUD/FUI Input System - Futuristic input components with Electric Blue on Deep Charcoal aesthetic",
  
  "types": {
    "default": {
      "border": "2px solid",
      "background": "rgba(0, 163, 255, 0.08)",
      "backdropFilter": "blur(8px)",
      "description": "Glass effect with subtle background fill"
    },
    "outline": {
      "border": "2px solid",
      "background": "transparent",
      "description": "Border only with transparent background"
    },
    "solid": {
      "border": "none",
      "background": "rgba(0, 163, 255, 0.85)",
      "description": "Translucent 85% filled background"
    }
  },
  
  "versions": {
    "angular-corner": {
      "name": "Angular Corner",
      "enabled": true,
      "description": "Beveled corners with glowing cyan borders and tech-notches",
      "clipPath": "polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px)",
      "features": ["corner-accents", "scan-line", "glow-border"],
      "animations": {
        "focus": "border-glow-intensify",
        "typing": "pulse-subtle",
        "entrance": "slide-in"
      }
    },
    "holo-frame": {
      "name": "Holographic Frame",
      "enabled": true,
      "description": "Iridescent holographic border with animated rainbow gradient",
      "clipPath": "polygon(12px 0, calc(100% - 12px) 0, 100% 12px, 100% calc(100% - 12px), calc(100% - 12px) 100%, 12px 100%, 0 calc(100% - 12px), 0 12px)",
      "features": ["corner-brackets", "particle-effects", "iridescent-border"],
      "animations": {
        "focus": "holo-intensify",
        "continuous": "holo-rotate",
        "entrance": "holo-fade"
      }
    },
    "data-panel": {
      "name": "Data Panel",
      "enabled": true,
      "description": "Side technical panel with status indicators and readouts",
      "clipPath": "polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%)",
      "features": ["side-panel", "status-leds", "data-readout"],
      "animations": {
        "focus": "panel-activate",
        "continuous": "scan-vertical",
        "entrance": "slide-reveal"
      }
    },
    "circuit-board": {
      "name": "Circuit Board",
      "enabled": true,
      "description": "Circuit trace patterns with animated electrical pulses",
      "clipPath": "polygon(6px 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%, 0 6px)",
      "features": ["circuit-pattern", "animated-traces", "corner-nodes"],
      "animations": {
        "focus": "trace-activate",
        "continuous": "pulse-traces",
        "entrance": "glitch-in"
      }
    },
    "quantum-gate": {
      "name": "Quantum Gate",
      "enabled": true,
      "description": "Quantum-inspired with particle effects and wave visualization",
      "clipPath": "polygon(4px 0, calc(100% - 4px) 0, 100% 4px, 100% calc(100% - 4px), calc(100% - 4px) 100%, 4px 100%, 0 calc(100% - 4px), 0 4px)",
      "features": ["quantum-particles", "wave-function", "state-indicators"],
      "animations": {
        "focus": "quantum-activate",
        "continuous": "quantum-pulse",
        "entrance": "quantum-fade"
      }
    },
    "tactical-hud": {
      "name": "Tactical HUD",
      "enabled": true,
      "description": "Military HUD aesthetic with targeting reticle and radar sweep",
      "clipPath": "polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px))",
      "features": ["radar-sweep", "targeting-reticle", "stealth-indicators"],
      "animations": {
        "focus": "target-lock",
        "continuous": "radar-sweep",
        "entrance": "hud-boot"
      }
    },
    "energy-shield": {
      "name": "Energy Shield",
      "enabled": true,
      "description": "Hexagonal shield pattern with pulsating energy waves",
      "clipPath": "polygon(10px 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 10px 100%, 0 50%)",
      "features": ["hexagon-pattern", "energy-waves", "shield-status"],
      "animations": {
        "focus": "shield-activate",
        "continuous": "pulse-wave",
        "entrance": "energy-burst"
      }
    },
    "terminal-window": {
      "name": "Terminal Window",
      "enabled": true,
      "description": "Terminal-style with command prompt aesthetic and CRT effects",
      "clipPath": "polygon(0 0, 100% 0, 100% calc(100% - 4px), calc(100% - 4px) 100%, 4px 100%, 0 calc(100% - 4px))",
      "features": ["terminal-header", "cursor-blink", "crt-flicker"],
      "animations": {
        "focus": "cursor-activate",
        "continuous": "scanline",
        "entrance": "terminal-boot"
      }
    },
    "matrix-grid": {
      "name": "Matrix Grid",
      "enabled": true,
      "description": "Animated grid overlay with digital rain effect",
      "clipPath": "polygon(6px 0, calc(100% - 6px) 0, 100% 6px, 100% calc(100% - 6px), calc(100% - 6px) 100%, 6px 100%, 0 calc(100% - 6px), 0 6px)",
      "features": ["animated-grid", "digital-rain", "corner-nodes"],
      "animations": {
        "focus": "grid-intensify",
        "continuous": "digital-rain",
        "entrance": "matrix-load"
      }
    },
    "neon-outline": {
      "name": "Neon Outline",
      "enabled": true,
      "description": "High-contrast neon glow with thick outer bloom",
      "clipPath": "polygon(4px 0, calc(100% - 4px) 0, 100% 4px, 100% calc(100% - 4px), calc(100% - 4px) 100%, 4px 100%, 0 calc(100% - 4px), 0 4px)",
      "features": ["thick-glow", "corner-leds", "pulsing-brightness"],
      "animations": {
        "focus": "neon-intensify",
        "continuous": "neon-pulse",
        "entrance": "neon-flicker"
      }
    }
  },
  
  "animations": {
    "slide-in": {
      "duration": "400ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "holo-fade": {
      "duration": "800ms",
      "easing": "ease-in-out"
    },
    "slide-reveal": {
      "duration": "600ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "glitch-in": {
      "duration": "600ms",
      "easing": "steps(4)"
    },
    "quantum-fade": {
      "duration": "800ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "hud-boot": {
      "duration": "500ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "energy-burst": {
      "duration": "600ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "terminal-boot": {
      "duration": "800ms",
      "easing": "steps(6)"
    },
    "matrix-load": {
      "duration": "900ms",
      "easing": "linear"
    },
    "neon-flicker": {
      "duration": "700ms",
      "easing": "steps(1)"
    },
    "border-glow-intensify": {
      "duration": "300ms",
      "easing": "ease-out"
    },
    "holo-rotate": {
      "duration": "4s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "scan-vertical": {
      "duration": "3s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "pulse-traces": {
      "duration": "2.5s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "quantum-pulse": {
      "duration": "3s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    },
    "radar-sweep": {
      "duration": "4s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "pulse-wave": {
      "duration": "3s",
      "iterationCount": "infinite",
      "easing": "ease-out"
    },
    "scanline": {
      "duration": "2s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "digital-rain": {
      "duration": "2s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "neon-pulse": {
      "duration": "2s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    }
  },
  
  "defaults": {
    "version": "angular-corner",
    "type": "default",
    "variant": "neutral",
    "animated": true,
    "size": "md"
  }
}
