{
  "version": "1.0",
  "component": "button",
  "description": "Cyber HUD/FUI Button System - Futuristic button components with unique shapes and animations",
  
  "types": {
    "default": {
      "border": "2px solid",
      "background": "rgba(0, 163, 255, 0.08)",
      "backdropFilter": "blur(8px)",
      "description": "Glass effect with subtle background fill"
    },
    "outline": {
      "border": "2px solid",
      "background": "transparent",
      "description": "Border only with transparent background"
    },
    "solid": {
      "border": "1px solid",
      "background": "rgba(0, 163, 255, 0.85)",
      "description": "Solid 85% opacity fill"
    }
  },
  
  "versions": {
    "angular-corner": {
      "name": "Angular Corner",
      "enabled": true,
      "description": "Beveled corners with glowing cyan borders and tech-notches",
      "clipPath": "polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px)",
      "features": ["corner-accents", "scan-line", "glow-border"],
      "animations": {
        "entrance": "popup-corner",
        "hover": "border-pulse",
        "exit": "popup-corner"
      }
    },
    "holo-frame": {
      "name": "Holographic Frame",
      "enabled": true,
      "description": "Octagonal with iridescent holographic border and shimmer",
      "clipPath": "polygon(10px 0, calc(100% - 10px) 0, 100% 10px, 100% calc(100% - 10px), calc(100% - 10px) 100%, 10px 100%, 0 calc(100% - 10px), 0 10px)",
      "features": ["corner-brackets", "shimmer-effect", "iridescent-border"],
      "animations": {
        "entrance": "holo-fade",
        "hover": "glow-intensify",
        "exit": "holo-fade",
        "continuous": "shimmer"
      }
    },
    "data-panel": {
      "name": "Data Panel",
      "enabled": true,
      "description": "Asymmetric cut with side accent and status indicator",
      "clipPath": "polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 0 100%)",
      "features": ["side-accent", "status-led", "data-readout"],
      "animations": {
        "entrance": "slide-reveal",
        "hover": "accent-glow"
      }
    },
    "circuit-board": {
      "name": "Circuit Board",
      "enabled": true,
      "description": "Circuit trace patterns with animated electrical pulses",
      "clipPath": "polygon(6px 0, calc(100% - 6px) 0, 100% 6px, 100% calc(100% - 6px), calc(100% - 6px) 100%, 6px 100%, 0 calc(100% - 6px), 0 6px)",
      "features": ["circuit-pattern", "animated-traces", "corner-nodes"],
      "animations": {
        "entrance": "glitch-in",
        "hover": "pulse-traces"
      }
    },
    "quantum-gate": {
      "name": "Quantum Gate",
      "enabled": true,
      "description": "Hexagonal quantum-inspired design with wave patterns",
      "clipPath": "polygon(12px 0, calc(100% - 12px) 0, 100% 50%, calc(100% - 12px) 100%, 12px 100%, 0 50%)",
      "features": ["quantum-particles", "wave-function", "entanglement-dots"],
      "animations": {
        "entrance": "quantum-fade",
        "hover": "quantum-pulse"
      }
    },
    "tactical-hud": {
      "name": "Tactical HUD",
      "enabled": true,
      "description": "Military HUD aesthetic with targeting reticle elements",
      "clipPath": "polygon(10px 0, calc(100% - 10px) 0, 100% 10px, 100% calc(100% - 10px), calc(100% - 10px) 100%, 10px 100%, 0 calc(100% - 10px), 0 10px)",
      "features": ["targeting-marks", "corner-brackets", "status-readout"],
      "animations": {
        "entrance": "tactical-deploy",
        "hover": "target-lock"
      }
    },
    "energy-shield": {
      "name": "Energy Shield",
      "enabled": true,
      "description": "Force field effect with pulsating energy waves",
      "clipPath": "polygon(8px 0, calc(100% - 8px) 0, 100% 50%, calc(100% - 8px) 100%, 8px 100%, 0 50%)",
      "features": ["energy-waves", "shield-glow", "hex-pattern"],
      "animations": {
        "entrance": "energy-burst",
        "hover": "shield-pulse",
        "continuous": "energy-flow"
      }
    },
    "terminal-window": {
      "name": "Terminal Window",
      "enabled": true,
      "description": "Command line aesthetic with CRT effects and scanlines",
      "clipPath": "polygon(4px 0, 100% 0, 100% 100%, 0 100%, 0 4px)",
      "features": ["terminal-header", "scanline", "cursor-blink"],
      "animations": {
        "entrance": "terminal-boot",
        "hover": "crt-flicker"
      }
    },
    "matrix-grid": {
      "name": "Matrix Grid",
      "enabled": true,
      "description": "Digital grid pattern with data flow visualization",
      "clipPath": "polygon(6px 0, calc(100% - 6px) 0, 100% 6px, 100% calc(100% - 6px), calc(100% - 6px) 100%, 6px 100%, 0 calc(100% - 6px), 0 6px)",
      "features": ["grid-overlay", "data-flow", "corner-nodes"],
      "animations": {
        "entrance": "matrix-load",
        "hover": "grid-pulse"
      }
    },
    "neon": {
      "name": "Neon Outline",
      "enabled": true,
      "description": "High-contrast neon glow with thick outer bloom effect",
      "clipPath": "polygon(4px 0, calc(100% - 4px) 0, 100% 4px, 100% calc(100% - 4px), calc(100% - 4px) 100%, 4px 100%, 0 calc(100% - 4px), 0 4px)",
      "features": ["thick-glow", "corner-leds", "pulsing-brightness"],
      "animations": {
        "entrance": "neon-flicker",
        "hover": "neon-intensify",
        "continuous": "neon-pulse"
      }
    }
  },
  
  "animations": {
    "popup-corner": {
      "duration": "300ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "holo-fade": {
      "duration": "400ms",
      "easing": "ease-out"
    },
    "slide-reveal": {
      "duration": "350ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "glitch-in": {
      "duration": "300ms",
      "easing": "steps(4)"
    },
    "quantum-fade": {
      "duration": "400ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "tactical-deploy": {
      "duration": "300ms",
      "easing": "ease-out"
    },
    "energy-burst": {
      "duration": "350ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "terminal-boot": {
      "duration": "400ms",
      "easing": "steps(6)"
    },
    "matrix-load": {
      "duration": "450ms",
      "easing": "linear"
    },
    "neon-flicker": {
      "duration": "350ms",
      "easing": "steps(1)"
    },
    "border-pulse": {
      "duration": "1.5s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    },
    "shimmer": {
      "duration": "2s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "pulse-traces": {
      "duration": "1.5s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "quantum-pulse": {
      "duration": "2s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    },
    "energy-flow": {
      "duration": "2s",
      "iterationCount": "infinite",
      "easing": "ease-out"
    },
    "neon-pulse": {
      "duration": "1.5s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    },
    "glow-intensify": {
      "duration": "200ms",
      "easing": "ease-out"
    }
  },
  
  "defaults": {
    "version": "angular-corner",
    "type": "default",
    "variant": "neutral",
    "animated": true
  }
}
