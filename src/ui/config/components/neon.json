{
  "name": "neon",
  "tokens": {
    "colors": {
      "--ne-cyan": "#00f5ff",
      "--ne-pink": "#ff0090",
      "--ne-yellow": "#ffee00",
      "--ne-green": "#00ff55",
      "--ne-orange": "#ff6600",
      "--ne-purple": "#cc00ff",
      "--ne-primary": "var(--ne-cyan)",
      "--ne-secondary": "var(--ne-pink)",
      "--ne-bg": "#050508",
      "--ne-text-primary": "#e6f0ff",
      "--ne-text-secondary": "rgba(230, 240, 255, 0.6)"
    },
    "fonts": {
      "display": "'Bungee', 'Black Han Sans', sans-serif",
      "body": "'Barlow Condensed', sans-serif",
      "code": "'Share Tech Mono', monospace"
    },
    "effects": {
      "tube-glow": "inset 0 0 6px var(--ne-primary), 0 0 4px var(--ne-primary), 0 0 12px var(--ne-primary), 0 0 24px rgba(0, 245, 255, 0.3)"
    }
  }
}
