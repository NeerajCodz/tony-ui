{
  "version": "1.0",
  "component": "avatar",
  "description": "Cyber HUD/FUI Avatar System - Futuristic avatar components with unique shapes and glow effects",
  
  "types": {
    "default": {
      "border": "2px solid",
      "background": "rgba(0, 163, 255, 0.1)",
      "backdropFilter": "blur(8px)",
      "description": "Glass effect with subtle background fill"
    },
    "outline": {
      "border": "2px solid",
      "background": "transparent",
      "description": "Border only with transparent background"
    },
    "solid": {
      "border": "none",
      "background": "rgba(0, 163, 255, 0.9)",
      "description": "Filled background without border"
    }
  },
  
  "sizes": {
    "sm": {
      "size": "32px",
      "fontSize": "12px",
      "statusSize": "8px"
    },
    "md": {
      "size": "48px",
      "fontSize": "16px",
      "statusSize": "10px"
    },
    "lg": {
      "size": "64px",
      "fontSize": "20px",
      "statusSize": "12px"
    },
    "xl": {
      "size": "96px",
      "fontSize": "28px",
      "statusSize": "16px"
    }
  },
  
  "versions": {
    "angular-corner": {
      "name": "Angular Corner",
      "enabled": true,
      "description": "Beveled corners with tech aesthetic",
      "clipPath": "polygon(15% 0%, 85% 0%, 100% 15%, 100% 85%, 85% 100%, 15% 100%, 0% 85%, 0% 15%)",
      "features": ["corner-accents", "glow-border", "scan-effect"],
      "animations": {
        "entrance": "avatar-enter",
        "hover": "glow-pulse"
      }
    },
    "hexagon": {
      "name": "Hexagon",
      "enabled": true,
      "description": "Hexagonal shape with sci-fi aesthetic",
      "clipPath": "polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%)",
      "features": ["hex-border", "glow-effect", "pulse-animation"],
      "animations": {
        "entrance": "avatar-enter",
        "hover": "hex-pulse"
      }
    },
    "octagon": {
      "name": "Octagon",
      "enabled": true,
      "description": "Octagonal military badge style",
      "clipPath": "polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%)",
      "features": ["oct-border", "corner-dots", "tactical-glow"],
      "animations": {
        "entrance": "avatar-enter",
        "hover": "tactical-pulse"
      }
    },
    "diamond": {
      "name": "Diamond",
      "enabled": true,
      "description": "Diamond shape with energy core effect",
      "clipPath": "polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%)",
      "features": ["diamond-glow", "rotation-effect", "energy-pulse"],
      "animations": {
        "entrance": "diamond-enter",
        "hover": "rotate-glow"
      }
    },
    "circuit-node": {
      "name": "Circuit Node",
      "enabled": true,
      "description": "Circuit board node with trace lines",
      "clipPath": "polygon(20% 0%, 80% 0%, 100% 20%, 100% 80%, 80% 100%, 20% 100%, 0% 80%, 0% 20%)",
      "features": ["circuit-traces", "node-glow", "data-pulse"],
      "animations": {
        "entrance": "circuit-boot",
        "hover": "trace-pulse"
      }
    },
    "holo-ring": {
      "name": "Holo Ring",
      "enabled": true,
      "description": "Circular with holographic ring effect",
      "clipPath": "circle(50% at 50% 50%)",
      "features": ["holo-border", "shimmer-effect", "ring-animation"],
      "animations": {
        "entrance": "holo-fade",
        "continuous": "holo-rotate"
      }
    },
    "tactical-badge": {
      "name": "Tactical Badge",
      "enabled": true,
      "description": "Military badge shape with HUD elements",
      "clipPath": "polygon(50% 0%, 90% 20%, 100% 60%, 75% 100%, 25% 100%, 0% 60%, 10% 20%)",
      "features": ["badge-frame", "rank-indicator", "status-leds"],
      "animations": {
        "entrance": "badge-reveal",
        "hover": "status-flash"
      }
    },
    "energy-core": {
      "name": "Energy Core",
      "enabled": true,
      "description": "Energy reactor core with pulsing waves",
      "clipPath": "polygon(25% 5%, 75% 5%, 95% 25%, 95% 75%, 75% 95%, 25% 95%, 5% 75%, 5% 25%)",
      "features": ["core-glow", "energy-waves", "power-indicator"],
      "animations": {
        "entrance": "energy-burst",
        "continuous": "pulse-wave"
      }
    },
    "quantum-state": {
      "name": "Quantum State",
      "enabled": true,
      "description": "Quantum-inspired octagram shape",
      "clipPath": "polygon(50% 0%, 85% 15%, 100% 50%, 85% 85%, 50% 100%, 15% 85%, 0% 50%, 15% 15%)",
      "features": ["quantum-blur", "state-indicator", "particle-effect"],
      "animations": {
        "entrance": "quantum-fade",
        "continuous": "quantum-pulse"
      }
    },
    "neon-frame": {
      "name": "Neon Frame",
      "enabled": true,
      "description": "High-contrast neon glow frame",
      "clipPath": "polygon(10% 0%, 90% 0%, 100% 10%, 100% 90%, 90% 100%, 10% 100%, 0% 90%, 0% 10%)",
      "features": ["neon-glow", "thick-border", "flicker-effect"],
      "animations": {
        "entrance": "neon-flicker",
        "continuous": "neon-pulse"
      }
    }
  },
  
  "status": {
    "online": {
      "color": "hsl(var(--success-base))",
      "glow": true
    },
    "offline": {
      "color": "hsl(var(--text-muted))",
      "glow": false
    },
    "busy": {
      "color": "hsl(var(--destructive-base))",
      "glow": true
    },
    "away": {
      "color": "hsl(var(--warning-base))",
      "glow": true
    }
  },
  
  "animations": {
    "avatar-enter": {
      "duration": "400ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "glow-pulse": {
      "duration": "2s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    },
    "hex-pulse": {
      "duration": "2.5s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    },
    "tactical-pulse": {
      "duration": "3s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "diamond-enter": {
      "duration": "500ms",
      "easing": "cubic-bezier(0.68, -0.55, 0.27, 1.55)"
    },
    "rotate-glow": {
      "duration": "4s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "circuit-boot": {
      "duration": "600ms",
      "easing": "steps(4)"
    },
    "trace-pulse": {
      "duration": "1.5s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "holo-fade": {
      "duration": "800ms",
      "easing": "ease-in-out"
    },
    "holo-rotate": {
      "duration": "4s",
      "iterationCount": "infinite",
      "easing": "linear"
    },
    "badge-reveal": {
      "duration": "500ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "status-flash": {
      "duration": "300ms",
      "easing": "ease-out"
    },
    "energy-burst": {
      "duration": "600ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "pulse-wave": {
      "duration": "3s",
      "iterationCount": "infinite",
      "easing": "ease-out"
    },
    "quantum-fade": {
      "duration": "700ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "quantum-pulse": {
      "duration": "4s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    },
    "neon-flicker": {
      "duration": "600ms",
      "easing": "steps(1)"
    },
    "neon-pulse": {
      "duration": "2s",
      "iterationCount": "infinite",
      "easing": "ease-in-out"
    }
  },
  
  "defaults": {
    "version": "hexagon",
    "type": "default",
    "variant": "neutral",
    "size": "md",
    "status": "none",
    "animated": true
  }
}
