{
  "version": "1.0",
  "component": "alert",
  "description": "Cyber HUD/FUI Alert System - Futuristic notification components",
  
  "types": {
    "default": {
      "border": "2px solid",
      "background": "rgba(0, 163, 255, 0.08)",
      "backdropFilter": "blur(8px)",
      "description": "Glass effect with subtle background fill"
    },
    "outline": {
      "border": "2px solid",
      "background": "transparent",
      "description": "Border only with transparent background"
    },
    "solid": {
      "border": "none",
      "background": "rgba(0, 163, 255, 0.9)",
      "description": "Translucent 90% filled background"
    }
  },
  
  "versions": {
    "angular-corner": {
      "name": "Angular Corner",
      "enabled": true,
      "description": "Beveled corners with glowing borders and tech-notches",
      "clipPath": "polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px)",
      "features": ["corner-accents", "scan-line", "glow-border"],
      "animations": {
        "entrance": "slideInRight",
        "hover": "border-pulse"
      }
    },
    "holo-frame": {
      "name": "Holographic Frame",
      "enabled": true,
      "description": "Iridescent holographic border with animated gradient",
      "clipPath": "polygon(8px 0, calc(100% - 8px) 0, 100% 8px, 100% calc(100% - 8px), calc(100% - 8px) 100%, 8px 100%, 0 calc(100% - 8px), 0 8px)",
      "features": ["corner-brackets", "iridescent-border"],
      "animations": {
        "entrance": "holoFade",
        "continuous": "holo-shimmer"
      }
    },
    "data-panel": {
      "name": "Data Panel",
      "enabled": true,
      "description": "Side technical panel with status indicators",
      "clipPath": "polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%)",
      "features": ["side-indicator", "status-leds"],
      "animations": {
        "entrance": "slideReveal",
        "continuous": "scan-vertical"
      }
    },
    "circuit-board": {
      "name": "Circuit Board",
      "enabled": true,
      "description": "Circuit trace patterns with animated pulses",
      "features": ["circuit-pattern", "corner-nodes"],
      "animations": {
        "entrance": "glitchIn",
        "continuous": "pulse-traces"
      }
    },
    "quantum-gate": {
      "name": "Quantum Gate",
      "enabled": true,
      "description": "Quantum-inspired with particle effects",
      "features": ["quantum-particles", "wave-function"],
      "animations": {
        "entrance": "quantumFade",
        "continuous": "quantum-pulse"
      }
    },
    "tactical-hud": {
      "name": "Tactical HUD",
      "enabled": true,
      "description": "Military HUD aesthetic with targeting elements",
      "clipPath": "polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px))",
      "features": ["targeting-bracket", "status-indicators"],
      "animations": {
        "entrance": "slideReveal",
        "continuous": "radar-sweep"
      }
    },
    "energy-shield": {
      "name": "Energy Shield",
      "enabled": true,
      "description": "Hexagonal shield pattern with energy waves",
      "features": ["hex-pattern", "energy-pulse"],
      "animations": {
        "entrance": "energyBurst",
        "continuous": "pulse-wave"
      }
    },
    "terminal-window": {
      "name": "Terminal Window",
      "enabled": true,
      "description": "Terminal-style with command prompt aesthetic",
      "features": ["terminal-header", "prompt-indicator"],
      "animations": {
        "entrance": "terminalBoot",
        "continuous": "cursor-blink"
      }
    },
    "matrix-grid": {
      "name": "Matrix Grid",
      "enabled": true,
      "description": "Animated grid overlay with digital effect",
      "clipPath": "polygon(6px 0, calc(100% - 6px) 0, 100% 6px, 100% calc(100% - 6px), calc(100% - 6px) 100%, 6px 100%, 0 calc(100% - 6px), 0 6px)",
      "features": ["grid-overlay", "corner-nodes"],
      "animations": {
        "entrance": "matrixLoad",
        "continuous": "grid-pulse"
      }
    },
    "neon": {
      "name": "Neon Outline",
      "enabled": true,
      "description": "High-contrast neon glow with thick outer bloom",
      "clipPath": "polygon(4px 0, calc(100% - 4px) 0, 100% 4px, 100% calc(100% - 4px), calc(100% - 4px) 100%, 4px 100%, 0 calc(100% - 4px), 0 4px)",
      "features": ["thick-glow", "corner-leds"],
      "animations": {
        "entrance": "neonFlicker",
        "continuous": "neon-pulse"
      }
    }
  },
  
  "animations": {
    "slideInRight": {
      "duration": "400ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "holoFade": {
      "duration": "600ms",
      "easing": "ease-in-out"
    },
    "slideReveal": {
      "duration": "500ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "glitchIn": {
      "duration": "400ms",
      "easing": "steps(4)"
    },
    "quantumFade": {
      "duration": "600ms",
      "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "energyBurst": {
      "duration": "500ms",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "terminalBoot": {
      "duration": "600ms",
      "easing": "steps(6)"
    },
    "matrixLoad": {
      "duration": "700ms",
      "easing": "linear"
    },
    "neonFlicker": {
      "duration": "500ms",
      "easing": "steps(1)"
    }
  },
  
  "defaults": {
    "version": "angular-corner",
    "type": "default",
    "variant": "neutral",
    "animated": true
  }
}
