{
  "fonts": {
    "primary": "'Poppins', sans-serif",
    "secondary": "'Inter', sans-serif",
    "heading": "'Orbitron', sans-serif",
    "button": "'Poppins', sans-serif",
    "monospace": "'Fira Code', monospace"
  },
  "weights": {
    "thin": "100",
    "light": "300",
    "regular": "400",
    "medium": "500",
    "semibold": "600",
    "bold": "700",
    "extrabold": "800",
    "black": "900"
  },
  "sizes": {
    "xs": "0.75rem",    
    "sm": "0.875rem",   
    "base": "1rem",     
    "md": "1.125rem",   
    "lg": "1.25rem",    
    "xl": "1.5rem",     
    "2xl": "1.875rem",  
    "3xl": "2.25rem",   
    "4xl": "3rem",      
    "5xl": "3.75rem",   
    "6xl": "4.5rem"     
  },
  "heights": {
    "tight": "1.1",
    "snug": "1.25",
    "normal": "1.5",
    "relaxed": "1.625",
    "loose": "1.75"
  },
  "spacing": {
    "tight": "-0.02em",
    "normal": "0em",
    "wide": "0.05em"
  },
  "headings": {
    "h1": {
      "font": "heading",
      "size": "6xl",
      "weight": "bold",
      "height": "tight"
    },
    "h2": {
      "font": "heading",
      "size": "5xl",
      "weight": "semibold",
      "height": "tight"
    },
    "h3": {
      "font": "heading",
      "size": "4xl",
      "weight": "semibold",
      "height": "snug"
    },
    "h4": {
      "font": "heading",
      "size": "3xl",
      "weight": "medium",
      "height": "snug"
    },
    "h5": {
      "font": "heading",
      "size": "2xl",
      "weight": "medium",
      "height": "normal"
    },
    "h6": {
      "font": "heading",
      "size": "xl",
      "weight": "medium",
      "height": "normal"
    }
  },
  "roles": {
    "normal": {
      "font": "primary",
      "size": "base",
      "weight": "regular",
      "height": "normal"
    },
    "primary": {
      "font": "primary",
      "size": "md",
      "weight": "medium",
      "height": "normal"
    },
    "secondary": {
      "font": "secondary",
      "size": "sm",
      "weight": "regular",
      "height": "normal"
    },
    "disabled": {
      "font": "primary",
      "size": "base",
      "weight": "light",
      "height": "relaxed",
      "opacity": 0.4
    },
    "button": {
      "font": "button",
      "size": "sm",
      "weight": "semibold",
      "spacing": "wide",
      "height": "tight",
      "textTransform": "uppercase"
    },
    "caption": {
      "font": "secondary",
      "size": "xs",
      "weight": "regular",
      "height": "snug",
      "spacing": "wide"
    }
  }
}
